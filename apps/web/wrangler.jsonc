{
  "name": "termpod-dev",
  "workers_dev": true,
  "compatibility_date": "2025-04-01",
  "compatibility_flags": ["nodejs_compat"],
  "routes": [
    { "pattern": "termpod.dev", "custom_domain": true }
  ],
  "assets": {
    "binding": "ASSETS",
    "directory": ".open-next/assets"
  },
  "main": ".open-next/worker.js"
}
