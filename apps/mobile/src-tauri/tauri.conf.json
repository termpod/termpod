{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-cli/schema.json",
  "productName": "Termpod",
  "version": "0.1.0",
  "identifier": "dev.termpod.mobile",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1430",
    "beforeDevCommand": "/Users/swapnil/.nvm/versions/node/v22.19.0/bin/pnpm vite",
    "beforeBuildCommand": "/Users/swapnil/.nvm/versions/node/v22.19.0/bin/pnpm vite build"
  },
  "app": {
    "windows": [
      {
        "title": "Termpod",
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
