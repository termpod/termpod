# Relay server WebSocket URL
# Desktop and mobile apps connect to this for session sharing
VITE_RELAY_URL=wss://relay.termpod.dev

# Relay server JWT secret (used by Cloudflare Worker)
# Generate a strong random string for production
JWT_SECRET=change-me-to-a-random-secret

# Apple Developer (for macOS code signing & iOS builds)
APPLE_TEAM_ID=YOUR_TEAM_ID
APPLE_SIGNING_IDENTITY=Developer ID Application: Your Name (YOUR_TEAM_ID)

# Apple notarization (for macOS distribution builds)
APPLE_ID=your-apple-id@example.com
APPLE_PASSWORD=your-app-specific-password

# Resend API key (for password reset emails)
# Create at: https://resend.com → API Keys
# Set via: wrangler secret put RESEND_API_KEY
# RESEND_API_KEY=re_xxxx

# Email sender address (for self-hosters — defaults to TermPod <noreply@email.termpod.dev>)
# Set via: wrangler secret put EMAIL_FROM
# EMAIL_FROM=YourApp <noreply@email.yourdomain.com>

# GitHub token (for update proxy — needs repo read access to private releases)
# Set via: wrangler secret put GITHUB_TOKEN
# GITHUB_TOKEN=ghp_xxxx

# Cloudflare TURN (for WebRTC P2P across NATs)
# Create at: https://dash.cloudflare.com → Calls → TURN Keys
# Set via: wrangler secret put TURN_KEY_ID && wrangler secret put TURN_KEY_API_TOKEN
# TURN_KEY_ID=your-turn-key-id
# TURN_KEY_API_TOKEN=your-turn-api-token

# Polar.sh (subscription billing — leave blank to disable, all features unlocked)
# Webhook secret from Polar dashboard → Settings → Webhooks
# Set via: wrangler secret put POLAR_WEBHOOK_SECRET
# POLAR_WEBHOOK_SECRET=whsec_xxxx
# Set via: wrangler secret put POLAR_API_KEY
# POLAR_API_KEY=polar_xxxx

# Polar.sh checkout links (website — leave blank to disable Pro CTAs)
# NEXT_PUBLIC_POLAR_CHECKOUT_URL=https://buy.polar.sh/polar_cl_xxxx
# NEXT_PUBLIC_POLAR_PORTAL_URL=https://polar.sh/termpod/portal

# Loops.so email subscription (website — leave blank to disable)
# LOOPS_API_KEY=xxxx

# Sentry error tracking (optional — leave blank to disable)
# Desktop: used via Vite env
VITE_SENTRY_DSN=
# Relay: set via wrangler secret put SENTRY_DSN
# SENTRY_DSN=
# iOS: injected via Config.xcconfig → Info.plist
# SENTRY_DSN=

# Tauri updater signing (must be set in shell env, NOT .env file)
# TAURI_SIGNING_PRIVATE_KEY=content-or-path-to-private-key
# TAURI_SIGNING_PRIVATE_KEY_PASSWORD=
