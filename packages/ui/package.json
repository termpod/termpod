{
  "name": "@termpod/ui",
  "version": "0.1.7",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./terminal": {
      "types": "./dist/terminal/Terminal.d.ts",
      "import": "./dist/terminal/Terminal.js"
    },
    "./session-list": {
      "types": "./dist/session-list/SessionList.d.ts",
      "import": "./dist/session-list/SessionList.js"
    },
    "./quick-actions": {
      "types": "./dist/quick-actions/QuickActions.d.ts",
      "import": "./dist/quick-actions/QuickActions.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@termpod/protocol": "workspace:*",
    "@termpod/shared": "workspace:*",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-search": "^0.16.0",
    "@xterm/addon-unicode-graphemes": "^0.4.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/xterm": "^6.0.0"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.12",
    "@types/react-dom": "^19.0.4",
    "typescript": "^5.8.2"
  }
}
